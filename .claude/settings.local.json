{
  "permissions": {
    "allow": [
      "Bash(export PATH=\"$PATH:/c/Program Files/nodejs\")",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(powershell:*)",
      "Bash(winget install:*)",
      "Bash(npx tsc:*)",
      "Bash(taskkill /F /IM node.exe)",
      "Bash(start \"\" \"http://localhost:3000/writer\")",
      "Bash(taskkill /PID 2328 /F)",
      "Read(//tmp/**)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(claude mcp:*)",
      "Skill(update-config)",
      "Skill(simplify)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "agent",
            "prompt": "A file was just written or edited. Use the Skill tool to invoke the 'simplify' skill. The edited file path is available in the tool_input (field 'file_path'). Review only the changed code for unnecessary complexity, duplicated logic, and efficiency issues, then apply fixes directly."
          }
        ]
      }
    ]
  }
}
